# ==================== Основная функция для генерации датасета ====================

def process_step_file_with_tolerances_and_pointcloud(step_file, output_dir,
                                                     generate_pointcloud=True,
                                                     generate_tolerances=True):
    """
    Process a single STEP file to generate:
    1. SVG drawing with tolerances
    2. 3D point cloud (with optional deviations)
    3. JSON annotation file with correspondences
    
    Args:
        step_file: Path to STEP file
        output_dir: Output directory
        generate_pointcloud: Whether to generate point cloud
        generate_tolerances: Whether to add tolerances to drawing
    """
    base_name = os.path.splitext(os.path.basename(step_file))[0]
    os.makedirs(output_dir, exist_ok=True)
    
    # Load shape
    shape = read_step_file(step_file)
    
    # Generate SVG drawing with tolerances
    svg_file = os.path.join(output_dir, f"{base_name}_drawing.svg")
    export_shape_to_svg_with_tolerances(
        shape, filename=svg_file,
        add_tolerances=generate_tolerances
    )
    
    # Generate point clouds
    if generate_pointcloud:
        pc_gen = PointCloudGenerator()
        
        # Ideal point cloud (no deviations)
        pc_ideal_file = os.path.join(output_dir, f"{base_name}_pc_ideal.npy")
        pc_gen.generate_pointcloud(step_file, pc_ideal_file, deviation_type='none')
        
        # Point cloud with in-tolerance deviations
        pc_in_tol_file = os.path.join(output_dir, f"{base_name}_pc_in_tol.npy")
        pc_gen.generate_pointcloud(step_file, pc_in_tol_file, 
                                  deviation_type='in_tolerance', max_deviation=0.05)
        
        # Point cloud with out-of-tolerance deviations
        pc_out_tol_file = os.path.join(output_dir, f"{base_name}_pc_out_tol.npy")
        pc_gen.generate_pointcloud(step_file, pc_out_tol_file,
                                  deviation_type='out_of_tolerance', max_deviation=0.15)
    
    # Create annotation file
    annotation = {
        'step_file': step_file,
        'svg_file': svg_file,
        'point_clouds': {
            'ideal': pc_ideal_file if generate_pointcloud else None,
            'in_tolerance': pc_in_tol_file if generate_pointcloud else None,
            'out_of_tolerance': pc_out_tol_file if generate_pointcloud else None
        },
        'metadata': {
            'model_name': base_name,
            'has_tolerances': generate_tolerances,
            'has_pointcloud': generate_pointcloud
        }
    }
    
    annotation_file = os.path.join(output_dir, f"{base_name}_annotation.json")
    with open(annotation_file, 'w') as f:
        json.dump(annotation, f, indent=2)
    
    return annotation


# ==================== Матрица проекции и согласование систем координат ====================

@dataclass
class ProjectionMatrix3DTo2D:
    """
    Матрица проекции для преобразования 3D точек в 2D координаты чертежа.
    Решает проблему разных систем координат.
    """
    matrix: np.ndarray  # 3x4 матрица проекции
    view_type: str  # 'front', 'top', 'side'
    scale_factor: float
    translation_2d: np.ndarray
    rotation_matrix: np.ndarray
    
    @classmethod
    def create_orthographic_projection(cls, view_direction: Tuple[float, float, float],
                                       up_direction: Tuple[float, float, float] = (0, 1, 0),
                                       scale: float = 1.0,
                                       translation: Tuple[float, float] = (0, 0)):
        """
        Создание ортографической проекции для заданного направления вида.
        
        Args:
            view_direction: Направление взгляда (куда смотрит камера)
            up_direction: Направление "верха" для ориентации проекции
            scale: Масштабный коэффициент
            translation: 2D смещение проекции
            
        Returns:
            ProjectionMatrix3DTo2D объект
        """
        view_dir = np.array(view_direction, dtype=np.float64)
        view_dir = view_dir / np.linalg.norm(view_dir)
        
        up_dir = np.array(up_direction, dtype=np.float64)
        up_dir = up_dir / np.linalg.norm(up_dir)
        
        # Вычисляем правую ось (right vector)
        right_dir = np.cross(view_dir, up_dir)
        right_dir = right_dir / np.linalg.norm(right_dir)
        
        # Пересчитываем up для ортогональности
        up_dir = np.cross(right_dir, view_dir)
        
        # Матрица вращения для выравнивания системы координат
        rotation = np.stack([right_dir, up_dir, -view_dir], axis=0)
        
        # Матрица проекции 3x4 (ортографическая - просто отбрасываем Z после вращения)
        projection_matrix = np.zeros((3, 4), dtype=np.float64)
        projection_matrix[:3, :3] = rotation
        projection_matrix[2, :] = 0  # Отбрасываем глубину
        
        # Применяем масштаб
        projection_matrix[:2, :3] *= scale
        
        return cls(
            matrix=projection_matrix,
            view_type=cls._get_view_type_name(view_direction),
            scale_factor=scale,
            translation_2d=np.array(translation),
            rotation_matrix=rotation
        )
    
    @staticmethod
    def _get_view_type_name(view_direction: Tuple[float, float, float]) -> str:
        """Определение типа вида по направлению."""
        dir_array = np.array(view_direction)
        dir_array = dir_array / np.linalg.norm(dir_array)
        
        if np.allclose(np.abs(dir_array), [0, 0, 1], atol=0.3):
            return 'front' if dir_array[2] > 0 else 'back'
        elif np.allclose(np.abs(dir_array), [0, 1, 0], atol=0.3):
            return 'top' if dir_array[1] > 0 else 'bottom'
        elif np.allclose(np.abs(dir_array), [1, 0, 0], atol=0.3):
            return 'right' if dir_array[0] > 0 else 'left'
        else:
            return 'isometric'
    
    def project_points(self, points_3d: np.ndarray) -> np.ndarray:
        """
        Проекция 3D точек в 2D координаты.
        
        Args:
            points_3d: Nx3 массив 3D точек
            
        Returns:
            Nx2 массив 2D координат
        """
        if points_3d.ndim == 1:
            points_3d = points_3d.reshape(1, -1)
        
        # Добавляем однородную координату
        points_homogeneous = np.hstack([points_3d, np.ones((points_3d.shape[0], 1))])
        
        # Применяем матрицу проекции
        points_2d_homogeneous = self.matrix @ points_homogeneous.T
        
        # Извлекаем 2D координаты и применяем смещение
        points_2d = points_2d_homogeneous[:2].T + self.translation_2d
        
        return points_2d
    
    def unproject_to_3d_ray(self, point_2d: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
        """
        Обратная проекция: 2D точка -> луч в 3D.
        
        Args:
            point_2d: 2D координаты на чертеже
            
        Returns:
            (origin, direction) - начало и направление луча в 3D
        """
        # Обратное вращение
        inv_rotation = self.rotation_matrix.T
        
        # 2D точка в системе координат камеры
        point_camera = np.array([
            (point_2d[0] - self.translation_2d[0]) / self.scale_factor,
            (point_2d[1] - self.translation_2d[1]) / self.scale_factor,
            0  # Z не определён в ортографической проекции
        ])
        
        # Начало луча (любая точка на луче проекции)
        origin = inv_rotation @ point_camera
        
        # Направление луча (перпендикулярно плоскости проекции)
        direction = -self.rotation_matrix[2]  # Направление взгляда
        
        return origin, direction


@dataclass
class FeatureCorrespondence:
    """
    Соответствие между признаком на чертеже и сегментом в облаке точек.
    """
    feature_id: str
    feature_type: str
    drawing_dimension: Dict
    pointcloud_segment: Dict
    nominal_value: float
    measured_value: float
    tolerance: Dict
    deviation: float
    projection_matrix: Dict
    confidence: float
    
    def to_dict(self) -> Dict:
        """Конвертация в словарь для JSON сериализации."""
        result = asdict(self)
        result['projection_matrix'] = {
            'matrix': self.projection_matrix['matrix'].tolist() 
                if isinstance(self.projection_matrix['matrix'], np.ndarray) 
                else self.projection_matrix['matrix'],
            'view_type': self.projection_matrix.get('view_type', 'unknown'),
            'scale_factor': self.projection_matrix.get('scale_factor', 1.0)
        }
        return result


class FeatureCorrespondenceCreator:
    """
    Создание соответствий между признаками на чертеже и в облаке точек.
    Решает проблему отсутствия прямого соответствия признаков.
    """
    
    def __init__(self, tolerance: float = 0.1):
        self.tolerance = tolerance  # Допуск для поиска соответствий
        self.projection_matrices: Dict[str, ProjectionMatrix3DTo2D] = {}
        
        # Инициализация стандартных проекций
        self._init_standard_projections()
    
    def _init_standard_projections(self):
        """Инициализация стандартных ортогональных проекций."""
        self.projection_matrices['front'] = ProjectionMatrix3DTo2D.create_orthographic_projection(
            view_direction=(0, 0, 1), scale=1.0
        )
        self.projection_matrices['top'] = ProjectionMatrix3DTo2D.create_orthographic_projection(
            view_direction=(0, 1, 0), scale=1.0
        )
        self.projection_matrices['side'] = ProjectionMatrix3DTo2D.create_orthographic_projection(
            view_direction=(1, 0, 0), scale=1.0
        )
    
    def extract_features_from_shape(self, shape: TopoDS_Shape) -> List[Dict]:
        """
        Извлечение геометрических признаков из B-Rep модели.
        
        Args:
            shape: TopoDS_Shape из STEP файла
            
        Returns:
            Список признаков с геометрической информацией
        """
        features = []
        feature_id = 0

        # Извлечение граней
        explorer = TopExp_Explorer(shape, TopAbs_FACE)
        while explorer.More():
            face = TopoDS_Face(explorer.Current())

            # Анализ типа поверхности
            surface = BRepAdaptor_Surface(face)
            surface_type = surface.GetType()

            # Вычисление bounding box
            bbox = Bnd_Box()
            brepbndlib_Add(face, bbox)

            if not bbox.IsVoid():
                xmin, ymin, zmin, xmax, ymax, zmax = bbox.Get()
                dimensions = [xmax - xmin, ymax - ymin, zmax - zmin]
                centroid = [(xmin + xmax) / 2, (ymin + ymax) / 2, (zmin + zmax) / 2]
                
                feature_type = self._classify_surface_type(surface_type)
                
                features.append({
                    'id': f'face_{feature_id}',
                    'type': feature_type,
                    'surface_type': int(surface_type),
                    'bbox': {'min': [xmin, ymin, zmin], 'max': [xmax, ymax, zmax]},
                    'dimensions': dimensions,
                    'centroid': centroid,
                    'area': self._compute_face_area(face)
                })
                feature_id += 1
            
            explorer.Next()
        
        # Извлечение рёбер (для отверстий, пазов и т.д.)
        explorer = TopExp_Explorer(shape, TopAbs_EDGE)
        edge_id = 0
        while explorer.More():
            edge = explorer.Current()
            
            curve = BRepAdaptor_Curve(edge)
            curve_type = curve.GetType()
            
            if curve_type == 1:  # Circle - потенциальное отверстие
                circle = curve.Circle()
                radius = circle.Radius()
                center = circle.Location().Coord()[:3]
                normal = circle.Axis().Direction().Coord()[:3]
                
                features.append({
                    'id': f'edge_circle_{edge_id}',
                    'type': 'hole' if radius < 10 else 'boss',
                    'radius': radius,
                    'diameter': 2 * radius,
                    'center': center,
                    'normal': normal,
                    'curve_type': 'circle'
                })
                edge_id += 1
            
            explorer.Next()
        
        return features
    
    def _classify_surface_type(self, surface_type: int) -> str:
        """Классификация типа поверхности."""
        type_map = {
            GeomAbs_Plane: 'plane',
            GeomAbs_Cylinder: 'cylinder',
            3: 'cone',
            4: 'sphere',
            5: 'torus',
            6: 'bspline',
            7: 'bezier',
            8: 'offset',
            9: 'other'
        }
        return type_map.get(surface_type, 'unknown')
    
    def _compute_face_area(self, face: TopoDS_Shape) -> float:
        """Вычисление площади грани."""
        props = GProp_GProps()
        brepgprop_SurfaceProperties(face, props)
        return props.Mass()
    
    def find_dimension_in_drawing(self, drawing: Dict, feature: Dict) -> Optional[Dict]:
        """
        Поиск размерной линии на чертеже, соответствующей признаку.
        
        Args:
            drawing: Словарь с данными чертежа
            feature: Признак из 3D модели
            
        Returns:
            Размерная линия или None
        """
        # Поиск в измерениях чертежа
        for view_name, view_data in drawing.items():
            if not isinstance(view_data, dict):
                continue
                
            dimensions = view_data.get('dimensions', [])
            for dim in dimensions:
                if self._dimension_matches_feature(dim, feature):
                    return dim
        
        return None
    
    def _dimension_matches_feature(self, dimension: Dict, feature: Dict) -> bool:
        """Проверка соответствия размерной линии признаку."""
        # Упрощённая эвристика - в реальной реализации нужно сравнивать
        # геометрические положения и типы признаков
        dim_type = dimension.get('type', '')
        feature_type = feature.get('type', '')
        
        # Проверка соответствия типов
        type_matches = {
            'hole': ['diameter', 'radius'],
            'cylinder': ['diameter', 'height'],
            'plane': ['length', 'width', 'distance']
        }
        
        for ft, dim_types in type_matches.items():
            if feature_type == ft and dimension.get('dimension_type') in dim_types:
                return True
        
        return False
    
    def find_points_in_pointcloud(self, points_3d: np.ndarray, 
                                  feature: Dict,
                                  shape: TopoDS_Shape = None) -> np.ndarray:
        """
        Поиск точек в облаке, принадлежащих признаку.
        
        Args:
            points_3d: Nx3 массив точек облака
            feature: Признак для поиска
            shape: Опционально, исходная форма для уточнения
            
        Returns:
            Массив точек, принадлежащих признаку
        """
        from scipy.spatial import KDTree
        
        feature_type = feature.get('type', '')
        feature_points = []
        
        if feature_type == 'hole':
            # Поиск точек на цилиндрической поверхности
            center = np.array(feature.get('center', [0, 0, 0]))
            radius = feature.get('radius', 0)
            normal = np.array(feature.get('normal', [0, 0, 1]))
            
            tree = KDTree(points_3d)
            
            # Точки вблизи цилиндрической поверхности
            for point in points_3d:
                # Расстояние до оси цилиндра
                to_center = point - center
                dist_to_axis = np.linalg.norm(to_center - np.dot(to_center, normal) * normal)
                
                if abs(dist_to_axis - radius) < self.tolerance:
                    feature_points.append(point)
        
        elif feature_type == 'plane':
            # Поиск точек на плоской поверхности
            bbox_min = np.array(feature.get('bbox', {}).get('min', [0, 0, 0]))
            bbox_max = np.array(feature.get('bbox', {}).get('max', [0, 0, 0]))
            
            mask = np.all((points_3d >= bbox_min - self.tolerance) & 
                         (points_3d <= bbox_max + self.tolerance), axis=1)
            feature_points = points_3d[mask]
        
        elif feature_type == 'cylinder':
            # Поиск точек на цилиндрической поверхности
            bbox_min = np.array(feature.get('bbox', {}).get('min', [0, 0, 0]))
            bbox_max = np.array(feature.get('bbox', {}).get('max', [0, 0, 0]))
            centroid = np.array(feature.get('centroid', [0, 0, 0]))
            
            # Точки в bounding box цилиндра
            mask = np.all((points_3d >= bbox_min - self.tolerance) & 
                         (points_3d <= bbox_max + self.tolerance), axis=1)
            feature_points = points_3d[mask]
        
        else:
            # Общий случай - использование bounding box
            if 'bbox' in feature:
                bbox_min = np.array(feature['bbox']['min'])
                bbox_max = np.array(feature['bbox']['max'])
                mask = np.all((points_3d >= bbox_min - self.tolerance) & 
                             (points_3d <= bbox_max + self.tolerance), axis=1)
                feature_points = points_3d[mask]
        
        return np.array(feature_points) if feature_points else np.array([])
    
    def compute_dimension_from_points(self, points: np.ndarray, 
                                      feature_type: str) -> float:
        """
        Вычисление фактического размера из облака точек.
        
        Args:
            points: Точки, принадлежащие признаку
            feature_type: Тип признака
            
        Returns:
            Измеренное значение
        """
        if len(points) == 0:
            return 0.0
        
        if feature_type in ['hole', 'cylinder']:
            # Вычисление диаметра через fitting цилиндра
            return self._fit_cylinder_diameter(points)
        elif feature_type == 'plane':
            # Вычисление размеров плоскости
            return self._compute_plane_dimension(points)
        elif feature_type == 'slot':
            # Вычисление длины паза
            return self._compute_slot_length(points)
        else:
            # Общий случай - максимальный размер
            return self._compute_max_dimension(points)
    
    def _fit_cylinder_diameter(self, points: np.ndarray) -> float:
        """Fitting цилиндра и возврат диаметра."""
        from scipy.spatial import KDTree
        
        # Вычисление центра и радиуса через PCA
        centroid = np.mean(points, axis=0)
        centered = points - centroid
        cov = np.cov(centered.T)
        eigvals, eigvecs = np.linalg.eigh(cov)
        
        # Ось цилиндра - eigenvector с наибольшим собственным значением
        axis = eigvecs[:, 2]
        
        # Проекция точек на плоскость, перпендикулярную оси
        proj_matrix = np.eye(3) - np.outer(axis, axis)
        projected = centered @ proj_matrix.T
        
        # Радиус как среднее расстояние до оси
        distances = np.linalg.norm(projected, axis=1)
        radius = np.mean(distances)
        
        return 2 * radius
    
    def _compute_plane_dimension(self, points: np.ndarray) -> float:
        """Вычисление размера плоскости."""
        bbox_min = np.min(points, axis=0)
        bbox_max = np.max(points, axis=0)
        dimensions = bbox_max - bbox_min
        
        # Возврат наибольшего размера
        return float(np.max(dimensions))
    
    def _compute_slot_length(self, points: np.ndarray) -> float:
        """Вычисление длины паза."""
        # PCA для определения направления паза
        centroid = np.mean(points, axis=0)
        centered = points - centroid
        cov = np.cov(centered.T)
        eigvals, eigvecs = np.linalg.eigh(cov)
        
        # Длина вдоль главной оси
        projected = centered @ eigvecs[:, 2]
        return float(np.max(projected) - np.min(projected))
    
    def _compute_max_dimension(self, points: np.ndarray) -> float:
        """Вычисление максимального размера."""
        bbox_min = np.min(points, axis=0)
        bbox_max = np.max(points, axis=0)
        dimensions = bbox_max - bbox_min
        return float(np.max(dimensions))
    
    def create_correspondences(self, shape: TopoDS_Shape,
                              drawing: Dict,
                              points_3d: np.ndarray,
                              view_type: str = 'front') -> List[FeatureCorrespondence]:
        """
        Создание полных соответствий между признаками на чертеже и в облаке точек.
        
        Args:
            shape: B-Rep модель
            drawing: Данные чертежа
            points_3d: 3D облако точек
            view_type: Тип проекции ('front', 'top', 'side')
            
        Returns:
            Список соответствий признаков
        """
        correspondences = []
        
        # 1. Извлечение признаков из модели
        features = self.extract_features_from_shape(shape)
        
        # 2. Получение матрицы проекции
        projection = self.projection_matrices.get(view_type, 
            ProjectionMatrix3DTo2D.create_orthographic_projection((0, 0, 1)))
        
        # 3. Для каждого признака создание соответствия
        for feature in features:
            # Поиск размерной линии на чертеже
            drawing_dimension = self.find_dimension_in_drawing(drawing, feature)
            
            if drawing_dimension is None:
                # Создание синтетического размера из геометрии
                nominal_value = self._get_nominal_value_from_feature(feature)
                drawing_dimension = {
                    'value': nominal_value,
                    'tolerance': {'value': nominal_value * 0.02, 'display': f'±{nominal_value * 0.02:.3f}'}
                }
            
            # Поиск точек в облаке
            feature_points = self.find_points_in_pointcloud(points_3d, feature, shape)
            
            if len(feature_points) == 0:
                continue
            
            # Вычисление фактического размера
            measured_value = self.compute_dimension_from_points(feature_points, feature['type'])
            
            # Вычисление отклонения
            nominal = drawing_dimension.get('value', measured_value)
            tolerance = drawing_dimension.get('tolerance', {'value': nominal * 0.05})
            deviation = abs(measured_value - nominal)
            
            # Создание соответствия
            correspondence = FeatureCorrespondence(
                feature_id=feature['id'],
                feature_type=feature['type'],
                drawing_dimension=drawing_dimension,
                pointcloud_segment={
                    'num_points': len(feature_points),
                    'centroid': np.mean(feature_points, axis=0).tolist(),
                    'bbox': {
                        'min': np.min(feature_points, axis=0).tolist(),
                        'max': np.max(feature_points, axis=0).tolist()
                    }
                },
                nominal_value=float(nominal),
                measured_value=float(measured_value),
                tolerance=tolerance,
                deviation=float(deviation),
                projection_matrix={
                    'matrix': projection.matrix,
                    'view_type': projection.view_type,
                    'scale_factor': projection.scale_factor
                },
                confidence=self._compute_correspondence_confidence(feature, feature_points)
            )
            
            correspondences.append(correspondence)
        
        return correspondences
    
    def _get_nominal_value_from_feature(self, feature: Dict) -> float:
        """Получение номинального значения из признака."""
        if 'diameter' in feature:
            return feature['diameter']
        elif 'radius' in feature:
            return 2 * feature['radius']
        elif 'dimensions' in feature:
            return max(feature['dimensions'])
        elif 'bbox' in feature:
            bbox_min = feature['bbox']['min']
            bbox_max = feature['bbox']['max']
            return max(np.array(bbox_max) - np.array(bbox_min))
        else:
            return 1.0
    
    def _compute_correspondence_confidence(self, feature: Dict, 
                                           points: np.ndarray) -> float:
        """Вычисление уверенности в соответствии."""
        confidence = 0.5
        
        # Уверенность растёт с количеством точек
        if len(points) > 100:
            confidence += 0.2
        elif len(points) > 50:
            confidence += 0.1
        
        # Уверенность растёт с типом признака
        known_types = ['hole', 'cylinder', 'plane', 'slot']
        if feature.get('type') in known_types:
            confidence += 0.2
        
        # Уверенность растёт с качеством fitting
        if 'radius' in feature or 'diameter' in feature:
            confidence += 0.1
        
        return min(confidence, 1.0)


def create_feature_correspondences(shape: TopoDS_Shape,
                                   drawing: Dict,
                                   points_3d: np.ndarray,
                                   view_type: str = 'front') -> List[Dict]:
    """
    Convenience function для создания соответствий признаков.
    
    Args:
        shape: B-Rep модель из STEP файла
        drawing: Данные чертежа
        points_3d: 3D облако точек
        view_type: Тип проекции
        
    Returns:
        Список соответствий в формате словарей
    """
    creator = FeatureCorrespondenceCreator()
    correspondences = creator.create_correspondences(shape, drawing, points_3d, view_type)
    return [c.to_dict() for c in correspondences]


# ==================== Масштабирование и нормализация ====================

class UnifiedScaler:
    """
    Единое масштабирование и нормализация для чертежей и облаков точек.
    Решает проблему масштабирования и нормализации.
    """
    
    def __init__(self, target_scale: float = 1.0, normalize_center: bool = True):
        self.target_scale = target_scale
        self.normalize_center = normalize_center
        self.scale_factor = 1.0
        self.translation = np.zeros(3)
        self.bbox_3d = None
        self.bbox_2d = None
    
    def fit(self, points_3d: np.ndarray, drawing_bbox_2d: Tuple = None):
        """
        Вычисление параметров масштабирования.
        
        Args:
            points_3d: 3D облако точек для вычисления bounding box
            drawing_bbox_2d: 2D bounding box чертежа (опционально)
        """
        # Вычисление 3D bounding box
        bbox_min = np.min(points_3d, axis=0)
        bbox_max = np.max(points_3d, axis=0)
        self.bbox_3d = {'min': bbox_min.tolist(), 'max': bbox_max.tolist()}
        
        # Диагональ bounding box для определения масштаба
        diagonal = np.linalg.norm(bbox_max - bbox_min)
        self.scale_factor = self.target_scale / (diagonal + 1e-10)
        
        # Центрирование
        if self.normalize_center:
            self.translation = -(bbox_min + bbox_max) / 2
        
        # Сохранение 2D bounding box если предоставлен
        if drawing_bbox_2d:
            self.bbox_2d = drawing_bbox_2d
        
        return self
    
    def transform_points(self, points_3d: np.ndarray) -> np.ndarray:
        """
        Применение масштабирования к 3D точкам.
        
        Args:
            points_3d: Nx3 массив точек
            
        Returns:
            Трансформированные точки
        """
        transformed = points_3d * self.scale_factor + self.translation
        return transformed
    
    def transform_drawing_coordinates(self, points_2d: np.ndarray) -> np.ndarray:
        """
        Применение согласованного масштабирования к 2D координатам чертежа.
        
        Args:
            points_2d: Nx2 массив 2D координат
            
        Returns:
            Трансформированные 2D координаты
        """
        # Для 2D применяем только масштабирование в плоскости XY
        scale_2d = self.scale_factor
        transformed = points_2d * scale_2d
        
        # Добавляем смещение если нужно
        if self.normalize_center and len(self.translation) >= 2:
            transformed += self.translation[:2]
        
        return transformed
    
    def get_normalization_params(self) -> Dict:
        """Получение параметров нормализации."""
        return {
            'scale_factor': float(self.scale_factor),
            'translation': self.translation.tolist(),
            'bbox_3d': self.bbox_3d,
            'bbox_2d': self.bbox_2d,
            'target_scale': self.target_scale,
            'normalize_center': self.normalize_center
        }


# ==================== Скрипт командной строки ====================

def main():
    """Main function for command-line usage."""
    import argparse
    
    parser = argparse.ArgumentParser(
        description='Render STEP files to SVG with tolerances and generate point clouds'
    )
    parser.add_argument('-i', '--input', dest='input_file', required=True,
                        help='Input STEP file or directory')
    parser.add_argument('-o', '--output', dest='output_dir', required=True,
                        help='Output directory')
    parser.add_argument('--width', default=800, type=int, help='SVG width')
    parser.add_argument('--height', default=600, type=int, help='SVG height')
    parser.add_argument('--no-tolerances', dest='add_tolerances', 
                        action='store_false', help='Do not add tolerances')
    parser.add_argument('--no-pointcloud', dest='generate_pointcloud',
                        action='store_false', help='Do not generate point clouds')
    
    args = parser.parse_args()
    
    if os.path.isdir(args.input_file):
        # Process all STEP files in directory
        step_files = []
        for root, dirs, files in os.walk(args.input_file):
            for file in files:
                if file.lower().endswith(('.step', '.stp')):
                    step_files.append(os.path.join(root, file))
        
        print(f"Found {len(step_files)} STEP files")
        
        for step_file in step_files:
            try:
                annotation = process_step_file_with_tolerances_and_pointcloud(
                    step_file, args.output_dir,
                    generate_pointcloud=args.generate_pointcloud,
                    generate_tolerances=args.add_tolerances
                )
                print(f"Processed: {os.path.basename(step_file)}")
            except Exception as e:
                print(f"Error processing {step_file}: {e}")
    else:
        # Process single file
        annotation = process_step_file_with_tolerances_and_pointcloud(
            args.input_file, args.output_dir,
            generate_pointcloud=args.generate_pointcloud,
            generate_tolerances=args.add_tolerances
        )
        print(f"Annotation saved to: {annotation}")


if __name__ == '__main__':
    main()