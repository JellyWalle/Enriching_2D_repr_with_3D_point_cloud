def read_step_file(filename, return_as_shapes=False, verbosity=True):
    """Read the STEP file and returns a compound."""
    if not os.path.isfile(filename):
        raise FileNotFoundError(f"{filename} not found.")
    
    step_reader = STEPControl_Reader()
    status = step_reader.ReadFile(filename)
    
    if status == IFSelect_RetDone:
        if verbosity:
            failsonly = False
            step_reader.PrintCheckLoad(failsonly, IFSelect_ItemsByEntity)
            step_reader.PrintCheckTransfer(failsonly, IFSelect_ItemsByEntity)
        
        shapes_to_return = []
        for root_num in range(1, step_reader.NbRootsForTransfer() + 1):
            transfer_result = step_reader.TransferRoot(root_num)
            if not transfer_result:
                raise AssertionError("Transfer failed.")
            shape = step_reader.Shape(root_num)
            if shape.IsNull():
                raise AssertionError("Shape is null.")
            shapes_to_return.append(shape)
        
        if return_as_shapes:
            return shapes_to_return
        
        builder = BRep_Builder()
        compound_shape = TopoDS_Compound()
        builder.MakeCompound(compound_shape)
        for shape in shapes_to_return:
            builder.Add(compound_shape, shape)
        return compound_shape
    else:
        raise AssertionError("Error: can't read file.")


def _Tcol_dim_1(li, _type):
    """Function factory for 1-dimensional TCol* types."""
    pts = _type(0, len(li) - 1)
    for n, i in enumerate(li):
        pts.SetValue(n, i)
    return pts


def point_list_to_TColgp_Array1OfPnt(li):
    return _Tcol_dim_1(li, TColgp_Array1OfPnt)


def add_to_bounding_box(points_2d):
    box2d = Bnd_Box2d()
    for p in points_2d:
        box2d.Add(gp_Pnt2d(*p))
    return box2d


def line_to_svg(curve):
    line = curve.Line()
    location = np.array(line.Location().Coord()[:2])
    direction = np.array(line.Direction().Coord()[:2])
    start = location + curve.FirstParameter() * direction
    end = location + curve.LastParameter() * direction
    return svgwrite.shapes.Line(start, end, fill="none"), add_to_bounding_box((start, end))


def approx_points_by_piecewise_bezier(points_3d, degree, tol):
    if degree not in (2, 3):
        raise RuntimeError("SVG files only support Bezier curves of degree 2 or 3")
    
    points_3d_occ = [gp_Pnt(*p) for p in points_3d]
    approx_spline = GeomAPI_PointsToBSpline(
        point_list_to_TColgp_Array1OfPnt(points_3d_occ), degree, degree, GeomAbs_C1, tol
    )
    
    if not approx_spline.IsDone():
        raise RuntimeError("Could not approximate points within a given tolerance")
    
    return GeomConvert_BSplineCurveToBezierCurve(approx_spline.Curve())


def piecewise_bezier_to_svg(points_2d, bezier_curves, degree):
    path_elements = []
    
    for i in range(1, bezier_curves.NbArcs() + 1):
        if bezier_curves.Arc(i).Degree() != degree:
            raise RuntimeError(f"Approximated degree of Bezier curves is not {degree}")
        
        curve = bezier_curves.Arc(i)
        if degree == 2:
            start, control, end = [p.Coord()[:2] for p in list(curve.Poles())]
            path_elements.append(f"M {start[0]},{start[1]} Q {control[0]},{control[1]} {end[0]},{end[1]}".split())
        elif degree == 3:
            start, first_control, second_control, end = [p.Coord()[:2] for p in list(curve.Poles())]
            path_elements.append(
                f"M {start[0]},{start[1]} C {first_control[0]},{first_control[1]} \
                {second_control[0]},{second_control[1]} {end[0]},{end[1]}".split()
            )
        path_elements.append(f"M{end[0]} {end[1]}".split())
    
    return svgwrite.path.Path(d=path_elements, fill="none"), add_to_bounding_box(points_2d)


def polyline_to_svg(points_2d):
    return svgwrite.shapes.Polyline(points_2d, fill="none"), add_to_bounding_box(points_2d)


# Note: discretize_edge and get_sorted_hlr_edges are imported from utils.topology_utils
# to use the memory-efficient implementation


def edge_to_svg(topods_edge, bezier_tol=0.01, bezier_degree=2):
    """Returns a svgwrite.Path for the edge, and the 2d bounding box."""
    curve = BRepAdaptor_Curve(topods_edge)
    
    if curve.GetType() == 0:  # line
        return line_to_svg(curve)
    else:
        # discretize the curve to process occlusions and transform to Bezier
        points_3d = discretize_edge(topods_edge, deflection=0.01)
        points_2d = [p[:2] for p in points_3d]
        
        try:
            return piecewise_bezier_to_svg(
                points_2d, 
                approx_points_by_piecewise_bezier(points_3d, bezier_degree, bezier_tol), 
                bezier_degree
            )
        except RuntimeError:
            print(f"Converting {CURVE_TYPES.get(curve.GetType(), 'Unknown')} to polyline")
            return polyline_to_svg(points_2d)


# ==================== Генерация допусков ====================

class ToleranceGenerator:
    """Генератор допусков для инженерных чертежей по стандарту ASME Y14.5"""
    
    def __init__(self, tolerance_config=None):
        self.tolerance_config = tolerance_config or {
            'default_tolerance_range': (0.01, 0.05),  # 1-5% от номинального размера
            'tolerance_types': ['±', 'upper_limit', 'lower_limit'],
            'feature_types': ['hole', 'slot', 'pocket', 'chamfer', 'fillet', 'step'],
            'geometric_tolerance_symbols': ['⏊', '◎', '⌖', '⌓', '⌰', '∠', '⌒'],
            'datum_identifiers': ['A', 'B', 'C', 'D', 'E', 'F']
        }
    
    def generate_linear_tolerance(self, nominal_value):
        """Генерация линейного допуска."""
        tolerance_type = random.choice(self.tolerance_config['tolerance_types'])
        tolerance_value = nominal_value * random.uniform(
            *self.tolerance_config['default_tolerance_range']
        )
        
        if tolerance_type == '±':
            return {
                'type': 'bilateral',
                'value': tolerance_value,
                'display': f'±{tolerance_value:.3f}',
                'upper_limit': nominal_value + tolerance_value,
                'lower_limit': nominal_value - tolerance_value
            }
        elif tolerance_type == 'upper_limit':
            return {
                'type': 'unilateral_upper',
                'value': tolerance_value,
                'display': f'+{tolerance_value:.3f}/0',
                'upper_limit': nominal_value + tolerance_value,
                'lower_limit': nominal_value
            }
        else:  # lower_limit
            return {
                'type': 'unilateral_lower',
                'value': tolerance_value,
                'display': f'0/-{tolerance_value:.3f}',
                'upper_limit': nominal_value,
                'lower_limit': nominal_value - tolerance_value
            }
    
    def generate_geometric_tolerance(self, feature_type):
        """Генерация геометрического допуска."""
        symbol = random.choice(self.tolerance_config['geometric_tolerance_symbols'])
        tolerance_value = random.uniform(0.01, 0.1)
        datum = random.choice(self.tolerance_config['datum_identifiers'])
        
        return {
            'type': 'geometric',
            'symbol': symbol,
            'value': tolerance_value,
            'datum': datum,
            'display': f'{symbol} {tolerance_value:.3f} ⌯ {datum}'
        }
    
    def create_dimension_line(self, start_point, end_point, value, tolerance=None):
        """Создание размерной линии с допуском."""
        dimension = {
            'type': 'dimension',
            'start': start_point,
            'end': end_point,
            'value': value,
            'tolerance': tolerance if tolerance else self.generate_linear_tolerance(value),
            'arrow_size': 5,
            'text_offset': 10
        }
        return dimension
    
    def create_feature_control_frame(self, position, geometric_tolerance, datum=None):
        """Создание рамки геометрического контроля."""
        fcf = {
            'type': 'feature_control_frame',
            'position': position,
            'geometric_tolerance': geometric_tolerance,
            'datum': datum,
            'box_size': (60, 20)  # ширина, высота рамки
        }
        return fcf
    
    def create_datum_feature(self, position, identifier):
        """Создание базовой плоскости."""
        datum = {
            'type': 'datum',
            'position': position,
            'identifier': identifier,
            'box_size': (20, 10)
        }
        return datum


# ==================== Генерация 3D облаков точек ====================

class PointCloudGenerator:
    """Генератор 3D облаков точек из моделей STEP."""
    
    def __init__(self, noise_config=None):
        self.noise_config = noise_config or {
            'gaussian_noise_std': 0.05,  # мм
            'outlier_percentage': 0.05,  # 5%
            'occlusion_probability': 0.1,  # 10%
            'num_points': 2048
        }
    
    def shape_to_mesh(self, shape, mesh_file):
        """Конвертация B-Rep модели в сетку."""
        # Use coarser mesh for memory efficiency
        mesh = BRepMesh_IncrementalMesh(shape, 0.5)  # Increased from 0.1 to 0.5
        mesh.Perform()
        
        stl_writer = StlAPI_Writer()
        stl_writer.Write(shape, mesh_file)
        
        return mesh_file
    
    def mesh_to_pointcloud(self, mesh_file, num_points=None):
        """Конвертация сетки в облако точек."""
        if num_points is None:
            num_points = self.noise_config['num_points']

        # Always use Open3D for efficient mesh loading and sampling
        import open3d as o3d
        mesh = o3d.io.read_triangle_mesh(mesh_file)
        
        # Convert to triangle mesh if needed and sample points
        if mesh.is_empty():
            raise ValueError(f"Mesh file {mesh_file} is empty or invalid")
            
        pcd = mesh.sample_points_uniformly(number_of_points=num_points)
        points = np.asarray(pcd.points)
        
        # Force garbage collection to free memory
        del mesh, pcd
        import gc
        gc.collect()

        return points
    
    def add_gaussian_noise(self, points, std_dev=None):
        """Добавление гауссова шума."""
        if std_dev is None:
            std_dev = self.noise_config['gaussian_noise_std']
        
        noise = np.random.normal(0, std_dev, points.shape)
        return points + noise
    
    def add_outliers(self, points, outlier_percentage=None):
        """Добавление выбросов."""
        if outlier_percentage is None:
            outlier_percentage = self.noise_config['outlier_percentage']
        
        num_outliers = int(len(points) * outlier_percentage)
        outlier_indices = np.random.choice(len(points), num_outliers, replace=False)
        
        outliers = np.random.uniform(-1.0, 1.0, (num_outliers, 3))
        points[outlier_indices] += outliers
        
        return points
    
    def add_occlusions(self, points, occlusion_probability=None):
        """Добавление окклюзий (пропущенных точек)."""
        if occlusion_probability is None:
            occlusion_probability = self.noise_config['occlusion_probability']
        
        if np.random.random() < occlusion_probability:
            num_occluded = int(len(points) * np.random.uniform(0.05, 0.15))
            occluded_indices = np.random.choice(len(points), num_occluded, replace=False)
            points = np.delete(points, occluded_indices, axis=0)
        
        return points
    
    def add_deviations(self, points, max_deviation, deviation_type='in_tolerance'):
        """Добавление отклонений."""
        if deviation_type == 'in_tolerance':
            # Максимальное отклонение: 50-80% от допуска
            max_dev = np.random.uniform(0.5, 0.8) * max_deviation
        elif deviation_type == 'out_of_tolerance':
            # Максимальное отклонение: 150-300% от допуска
            max_dev = np.random.uniform(1.5, 3.0) * max_deviation
        else:
            max_dev = 0
        
        noise = np.random.normal(0, max_dev / 3, points.shape)
        return points + noise
    
    def generate_pointcloud(self, step_file, output_file=None, 
                           deviation_type='none', max_deviation=None):
        """Полная генерация облака точек."""
        # Загрузка модели
        shape = read_step_file(step_file)
        
        # Создание временного файла для сетки
        mesh_file = step_file.replace('.step', '.stl').replace('.stp', '.stl')
        self.shape_to_mesh(shape, mesh_file)
        
        # Конвертация в облако точек
        points = self.mesh_to_pointcloud(mesh_file)
        
        # Добавление отклонений
        if deviation_type != 'none' and max_deviation is not None:
            points = self.add_deviations(points, max_deviation, deviation_type)
        
        # Добавление реалистичного шума
        points = self.add_gaussian_noise(points)
        points = self.add_outliers(points)
        points = self.add_occlusions(points)
        
        # Сохранение
        if output_file:
            np.save(output_file, points)
        
        # Очистка временного файла
        if os.path.exists(mesh_file):
            os.remove(mesh_file)
        
        return points


# ==================== Экспорт в формате с допусками ====================

def export_shape_to_svg_with_tolerances(shape, filename=None,
                                        width=800, height=600, margin_left=30,
                                        margin_top=30, export_hidden_edges=True,
                                        location=(0, 0, 0), direction=(1, 1, 1),
                                        bezier_degree=2, bezier_tol=0.01,
                                        color="black", line_width=0.5,
                                        add_tolerances=True):
    """
    Export a shape to SVG with optional tolerance annotations.
    """
    if shape.IsNull():
        raise AssertionError("shape is Null")
    
    # Find all edges
    location_gp = gp_Pnt(*location)
    direction_gp = gp_Dir(*direction)
    
    visible_edges, hidden_edges = get_sorted_hlr_edges(
        shape, position=location_gp, direction=direction_gp,
        export_hidden_edges=export_hidden_edges
    )
    
    # Compute paths for all edges
    global_2d_bounding_box = Bnd_Box2d()
    paths = []
    
    for visible_edge in visible_edges:
        visible_svg_line, visible_edge_box2d = edge_to_svg(
            visible_edge, bezier_degree=bezier_degree, bezier_tol=bezier_tol
        )
        if visible_svg_line:
            paths.append(visible_svg_line)
            global_2d_bounding_box.Add(visible_edge_box2d)
    
    if export_hidden_edges:
        for hidden_edge in hidden_edges:
            hidden_svg_line, hidden_edge_box2d = edge_to_svg(
                hidden_edge, bezier_degree=bezier_degree, bezier_tol=bezier_tol
            )
            if hidden_svg_line:
                hidden_svg_line.dasharray([5, 5])
                paths.append(hidden_svg_line)
                global_2d_bounding_box.Add(hidden_edge_box2d)
    
    # Translate and scale paths
    x_min, y_min, x_max, y_max = global_2d_bounding_box.Get()
    bb2d_width = x_max - x_min
    bb2d_height = y_max - y_min
    
    # Build the SVG drawing
    drawing = svgwrite.Drawing(filename, (width, height), debug=True)
    drawing.viewbox(x_min - margin_left, y_min - margin_top,
                    bb2d_width + 2 * margin_left, bb2d_height + 2 * margin_top)
    
    # Add paths
    for path in paths:
        path.stroke(color, width=line_width, linecap="round")
        drawing.add(path)

    # Add tolerances if requested - ASME Y14.5 style dimensions
    if add_tolerances:
        tolerance_gen = ToleranceGenerator()
        
        # Calculate bounding box for dimension placement
        x_min, y_min, x_max, y_max = global_2d_bounding_box.Get()
        center_x = (x_min + x_max) / 2
        center_y = (y_min + y_max) / 2
        
        # Generate ASME-style dimensions based on bounding box
        # Horizontal dimension (width)
        width = x_max - x_min
        height = y_max - y_min
        
        # Create dimension with tolerance
        width_value = round(width, 2)
        width_tolerance = tolerance_gen.generate_linear_tolerance(width_value)
        
        # Draw horizontal dimension line below the view
        dim_offset = 20  # Offset from geometry
        arrow_size = 8
        
        # Extension lines (vertical lines from geometry to dimension line)
        ext_line1 = svgwrite.shapes.Line(
            (x_min, y_min), (x_min, y_min + dim_offset + 15),
            stroke='black', stroke_width=0.35
        )
        ext_line2 = svgwrite.shapes.Line(
            (x_max, y_min), (x_max, y_min + dim_offset + 15),
            stroke='black', stroke_width=0.35
        )
        drawing.add(ext_line1)
        drawing.add(ext_line2)
        
        # Dimension line with arrowheads
        dim_line_y = y_min + dim_offset
        dim_line = svgwrite.shapes.Line(
            (x_min, dim_line_y), (x_max, dim_line_y),
            stroke='black', stroke_width=0.35
        )
        drawing.add(dim_line)
        
        # Arrowheads (filled triangles pointing inward)
        # Left arrowhead
        left_arrow = svgwrite.path.Path(
            d=f"M {x_min},{dim_line_y} L {x_min + arrow_size},{dim_line_y - 3} L {x_min + arrow_size},{dim_line_y + 3} Z",
            fill='black'
        )
        # Right arrowhead
        right_arrow = svgwrite.path.Path(
            d=f"M {x_max},{dim_line_y} L {x_max - arrow_size},{dim_line_y - 3} L {x_max - arrow_size},{dim_line_y + 3} Z",
            fill='black'
        )
        drawing.add(left_arrow)
        drawing.add(right_arrow)
        
        # Dimension text (centered, with gap in dimension line)
        dim_text_str = f"{width_value:.2f}"
        if width_tolerance.get('type') == 'bilateral':
            dim_text_str += f"±{width_tolerance['value']:.2f}"
        elif width_tolerance.get('type') == 'unilateral_upper':
            dim_text_str += f"+{width_tolerance['upper_limit'] - width_value:.2f}/0"
        elif width_tolerance.get('type') == 'unilateral_lower':
            dim_text_str += f"0/-{width_value - width_tolerance['lower_limit']:.2f}"
        
        # Text background (white box to hide dimension line)
        text_bg = svgwrite.shapes.Rect(
            insert=(center_x - 25, dim_line_y - 8),
            size=(50, 16),
            fill='white',
            stroke='none'
        )
        drawing.add(text_bg)
        
        # Dimension text
        dim_text = svgwrite.text.Text(
            dim_text_str,
            insert=(center_x, dim_line_y + 5),
            font_size='10',
            fill='black',
            text_anchor='middle',
            font_family='Arial, sans-serif'
        )
        drawing.add(dim_text)
        
        # Vertical dimension (height) - on the left side
        height_value = round(height, 2)
        height_tolerance = tolerance_gen.generate_linear_tolerance(height_value)
        
        # Extension lines (horizontal)
        v_dim_offset = 20
        ext_line3 = svgwrite.shapes.Line(
            (x_min, y_min), (x_min - v_dim_offset - 15, y_min),
            stroke='black', stroke_width=0.35
        )
        ext_line4 = svgwrite.shapes.Line(
            (x_min, y_max), (x_min - v_dim_offset - 15, y_max),
            stroke='black', stroke_width=0.35
        )
        drawing.add(ext_line3)
        drawing.add(ext_line4)
        
        # Vertical dimension line
        v_dim_line_x = x_min - v_dim_offset
        v_dim_line = svgwrite.shapes.Line(
            (v_dim_line_x, y_min), (v_dim_line_x, y_max),
            stroke='black', stroke_width=0.35
        )
        drawing.add(v_dim_line)
        
        # Vertical arrowheads
        top_arrow = svgwrite.path.Path(
            d=f"M {v_dim_line_x},{y_min} L {v_dim_line_x - 3},{y_min + arrow_size} L {v_dim_line_x + 3},{y_min + arrow_size} Z",
            fill='black'
        )
        bottom_arrow = svgwrite.path.Path(
            d=f"M {v_dim_line_x},{y_max} L {v_dim_line_x - 3},{y_max - arrow_size} L {v_dim_line_x + 3},{y_max - arrow_size} Z",
            fill='black'
        )
        drawing.add(top_arrow)
        drawing.add(bottom_arrow)
        
        # Vertical dimension text (rotated 90 degrees)
        v_dim_text_str = f"{height_value:.2f}"
        if height_tolerance.get('type') == 'bilateral':
            v_dim_text_str += f"±{height_tolerance['value']:.2f}"
        elif height_tolerance.get('type') == 'unilateral_upper':
            v_dim_text_str += f"+{height_tolerance['upper_limit'] - height_value:.2f}/0"
        elif height_tolerance.get('type') == 'unilateral_lower':
            v_dim_text_str += f"0/-{height_value - height_tolerance['lower_limit']:.2f}"
        
        # Text background for vertical dimension
        v_text_bg = svgwrite.shapes.Rect(
            insert=(v_dim_line_x - 20, (y_min + y_max) / 2 - 8),
            size=(40, 16),
            fill='white',
            stroke='none'
        )
        drawing.add(v_text_bg)
        
        # Vertical dimension text (rotated)
        v_dim_text = svgwrite.text.Text(
            v_dim_text_str,
            insert=(v_dim_line_x - 5, (y_min + y_max) / 2 + 3),
            font_size='10',
            fill='black',
            text_anchor='middle',
            font_family='Arial, sans-serif',
            transform=f'rotate(-90, {v_dim_line_x - 5}, {(y_min + y_max) / 2 + 3})'
        )
        drawing.add(v_dim_text)
        
        # Add GD&T Feature Control Frame (ASME Y14.5 style)
        # Position tolerance frame below horizontal dimension
        fcf_y = dim_line_y + 25
        fcf_x = center_x - 40
        
        # Feature control frame box
        fcf_box = svgwrite.shapes.Rect(
